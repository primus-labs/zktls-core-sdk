# Copy this file to .env and fill in your real credentials.
# Do not commit .env (it is in .gitignore).
ZKTLS_APP_ID=YOUR_APPID
ZKTLS_APP_SECRET=YOUR_APPSECRET

# Required only when running stream integration tests:
# ZKTLS_STREAM_INTEGRATION=true npm test -- test/stream.integration.test.ts
ZKTLS_STREAM_INTEGRATION=false
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini
