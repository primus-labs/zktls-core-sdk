{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "../..",
    "paths": {
      "*": ["src/*", "node_modules/*"]
    }
  },
  "include": ["soak/**/*.ts", "../../src/**/*.ts"],
  "exclude": ["../../node_modules", "../../dist"]
}
